# .gitignore file for Equinox Health Supplies

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Environment files
.env
.env.local

# Node modules (if you ever add them)
node_modules/

# Temporary files
*.tmp
*.temp

# Backup files
*.bak
*.backup

# Don't ignore your actual website files!
# All HTML, CSS, JS, images, sitemap.xml, robots.txt should be pushed